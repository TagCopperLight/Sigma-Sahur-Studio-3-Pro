# Copy this file to application-local.properties and fill in the values
# application-local.properties is gitignored and will never be committed

# --- Base de données MySQL ---
spring.datasource.url=jdbc:mysql://<host>:<port>/<schema>?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Europe/Paris
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password
